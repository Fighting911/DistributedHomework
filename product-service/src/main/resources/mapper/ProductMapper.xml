<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seckill.product.mapper.ProductMapper">

    <resultMap id="productResultMap" type="Product">
        <id     property="id"          column="id"/>
        <result property="name"        column="name"/>
        <result property="description" column="description"/>
        <result property="price"       column="price"/>
        <result property="status"      column="status"/>
        <result property="createdAt"   column="created_at"/>
        <result property="stock"       column="available"/>
    </resultMap>

    <select id="selectByIdWithStock" resultMap="productResultMap">
        SELECT p.*, i.available
        FROM t_product p
        LEFT JOIN t_inventory i ON i.product_id = p.id
        WHERE p.id = #{id} AND p.status = 1
    </select>

    <select id="selectAllWithStock" resultMap="productResultMap">
        SELECT p.*, i.available
        FROM t_product p
        LEFT JOIN t_inventory i ON i.product_id = p.id
        WHERE p.status = 1
        ORDER BY p.id
    </select>

</mapper>
